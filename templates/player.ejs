<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= film.titre %> - Lecteur - <%= siteSettings.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
    .video-wrapper {
        background: #000;
        border-radius: 8px;
        overflow: hidden;
    }
    .video-player {
        width: 100%;
        max-height: 80vh;
        display: block;
    }
    .video-wrapper iframe {
        width: 100%;
        height: 500px;
        border: none;
    }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: <%= siteSettings.secondaryColor %>;">
        <div class="container">
            <a class="navbar-brand site-title" href="/">
                <span class="stream-text">STREAM</span><span class="place-text">PLACE</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto"></ul>
                <form class="d-flex" action="/search" method="get">
                    <input class="form-control me-2" type="search" name="q" placeholder="Rechercher un film...">
                    <button class="btn btn-outline-light" type="submit"><i class="bi bi-search"></i></button>
                </form>
                <ul class="navbar-nav ms-2">
                    <% if (session && session.user) { %>
                    <li class="nav-item">
                        <a class="btn btn-danger ms-2" href="/admin">Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-2" href="/logout">Déconnexion</a>
                    </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            <div class="player-container">
                <h2 class="text-center mb-3"><%= film.titre %></h2>
                <div class="video-wrapper" id="videoContainer">
                    <% 
                    let embedUrl = film.video_url;
                    let videoType = 'iframe';
                    
                    if (film.video_url.includes('drive.google.com')) {
                        const match = film.video_url.match(/\/d\/([a-zA-Z0-9_-]+)/);
                        if (match) {
                            embedUrl = 'https://drive.google.com/file/d/' + match[1] + '/preview?usp=drivesdk';
                        }
                    } else if (film.video_url.includes('dropbox.com')) {
                        // Convert Dropbox URL to direct embed URL
                        let dropboxUrl = film.video_url;
                        // Replace dl=0 with raw=1 or add ?raw=1
                        if (dropboxUrl.includes('dl=0')) {
                            dropboxUrl = dropboxUrl.replace('dl=0', 'raw=1');
                        } else if (!dropboxUrl.includes('raw=1')) {
                            dropboxUrl = dropboxUrl + (dropboxUrl.includes('?') ? '&' : '?') + 'raw=1';
                        }
                        // Use dl.dropboxusercontent.com for better embed support
                        embedUrl = dropboxUrl.replace('www.dropbox.com', 'www.dl.dropboxusercontent.com');
                        videoType = 'video';
                    } else if (film.video_url.includes('mega.nz')) {
                        // Mega - use iframe embed
                        videoType = 'mega';
                    }
                    %>
                    <% if (videoType === 'video') { %>
                    <video controls playsinline class="video-player" preload="metadata" controlsList="nodownload">
                        <source src="<%= encodeURI(embedUrl) %>">
                        Votre navigateur ne supporte pas la lecture vidéo.
                    </video>
                    <% } else if (videoType === 'mega') { %>
                    <iframe id="videoIframe" src="<%= film.video_url %>" 
                            width="100%" 
                            height="500" 
                            frameborder="0" 
                            allow="autoplay; encrypted-media" 
                            allowfullscreen
                            sandbox="allow-scripts allow-same-origin allow-forms">
                    </iframe>
                    <% } else { %>
                    <iframe id="videoIframe" src="<%= encodeURI(embedUrl) %>" 
                            width="100%" 
                            height="500" 
                            frameborder="0" 
                            allow="autoplay; encrypted-media" 
                            allowfullscreen
                            sandbox="allow-scripts allow-same-origin allow-forms">
                    </iframe>
                    <% } %>
                </div>
                <div class="text-center mt-3">
                    <a href="/" class="btn btn-outline-light">
                        <i class="bi bi-arrow-left"></i> Retour au catalogue
                    </a>
                </div>
            </div>
        </div>
    </main>

    <footer class="text-light py-4 mt-5" style="background-color: <%= siteSettings.secondaryColor %>;">
        <div class="container text-center">
            <p class="mb-0"><%- siteSettings.footerText %></p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
