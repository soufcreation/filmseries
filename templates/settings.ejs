<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paramètres du site - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand site-title" href="/">
                <span class="stream-text">STREAM</span><span class="place-text">PLACE</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/admin">Admin</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-2">
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-2" href="/logout">Déconnexion</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Paramètres du site</h1>
                <a href="/admin" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            </div>

            <% if (flash && flash.length > 0) { %>
                <% flash.forEach(function(msg) { %>
                    <div class="alert alert-<%= msg.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show">
                        <%= msg.message %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% }); %>
            <% } %>

            <div class="card">
                <div class="card-header bg-dark">
                    <h5 class="mb-0">Configuration générale</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/admin/settings" enctype="multipart/form-data">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        
                        <!-- Nom du site -->
                        <div class="mb-4">
                            <label for="name" class="form-label fw-bold">Nom du site</label>
                            <input type="text" class="form-control" id="name" name="name" 
                                   value="<%= siteSettings.name %>" placeholder="Mon site de streaming">
                            <div class="form-text">Ce nom apparaît dans la barre de titre et le logo.</div>
                        </div>

                        <!-- Logo section -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Logo</label>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="logoUrl" class="form-label small">URL du logo</label>
                                    <input type="url" class="form-control" id="logoUrl" name="logoUrl" 
                                           value="<%= siteSettings.logoUrl %>" placeholder="https://exemple.com/logo.png">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="logo" class="form-label small">Ou upload (prioritaire)</label>
                                    <input type="file" class="form-control" id="logo" name="logo" accept="image/*">
                                </div>
                            </div>
                            <% if (siteSettings.logo || siteSettings.logoUrl) { %>
                            <div class="mt-2">
                                <p class="small text-muted mb-1">Aperçu du logo actuel:</p>
                                <img src="<%= siteSettings.logo || siteSettings.logoUrl %>" alt="Logo actuel" 
                                     style="max-height: 60px;" onerror="this.style.display='none'">
                            </div>
                            <% } %>
                        </div>

                        <!-- Footer text -->
                        <div class="mb-4">
                            <label for="footerText" class="form-label fw-bold">Texte du footer</label>
                            <textarea class="form-control" id="footerText" name="footerText" 
                                      rows="2"><%= siteSettings.footerText %></textarea>
                            <div class="form-text">Vous pouvez utiliser des balises HTML simples.</div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Enregistrer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0"><%- siteSettings.footerText %></p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>