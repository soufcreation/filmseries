<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= film.titre %> - Streaming</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-play-circle"></i> Streaming
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Accueil</a>
                    </li>
                </ul>
                <form class="d-flex" action="/search" method="get">
                    <input class="form-control me-2" type="search" name="q" placeholder="Rechercher un film...">
                    <button class="btn btn-outline-light" type="submit"><i class="bi bi-search"></i></button>
                </form>
                <ul class="navbar-nav ms-2">
                    <% if (session && session.user) { %>
                    <li class="nav-item">
                        <a class="btn btn-danger ms-2" href="/admin">Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-2" href="/logout">Déconnexion</a>
                    </li>
                    <% } else { %>
                    <li class="nav-item">
                        <a class="btn btn-primary ms-2" href="/login">Connexion</a>
                    </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="film-detail-card">
                        <div class="row">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <img src="<%= film.cover %>" alt="<%= film.titre %>" class="img-fluid rounded shadow" onerror="this.src='/images/covers/default.jpg'">
                            </div>
                            <div class="col-md-8">
                                <h1 class="film-title-detail"><%= film.titre %></h1>
                                <p class="film-description"><%= film.description %></p>
                                
                                <div class="ad-section my-4">
                                    <div class="ad-placeholder">
                                        <i class="bi bi-ad"></i>
                                        <span>PUBLICITÉ</span>
                                        <small>Votre annonce ici</small>
                                    </div>
                                </div>

                                <div class="d-grid gap-2">
                                    <a href="/film/<%= film.id %>/pub2" class="btn btn-continue btn-lg">
                                        <i class="bi bi-arrow-right"></i> Continuer
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 Streaming. Tous droits réservés.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
