<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - <%= siteSettings.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: <%= siteSettings.secondaryColor %>;">
        <div class="container">
            <a class="navbar-brand site-title" href="/">
                <span class="stream-text">STREAM</span><span class="place-text">PLACE</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto"></ul>
                <form class="d-flex" action="/search" method="get">
                    <input class="form-control me-2" type="search" name="q" placeholder="Rechercher un film...">
                    <button class="btn btn-outline-light" type="submit"><i class="bi bi-search"></i></button>
                </form>
                <ul class="navbar-nav ms-2">
                    <% if (session && session.user) { %>
                    <li class="nav-item">
                        <a class="btn btn-danger ms-2" href="/admin">Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-2" href="/logout">Déconnexion</a>
                    </li>
                    <% } else { %>
                    <li class="nav-item">
                        <a class="btn btn-primary ms-2" href="/login">Connexion</a>
                    </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Dashboard Admin</h1>
                <div>
                    <a href="/admin/settings" class="btn btn-outline-secondary me-2">
                        <i class="bi bi-gear"></i> Paramètres du site
                    </a>
                    <a href="/admin/add" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Ajouter un film
                    </a>
                </div>
            </div>

            <% if (flash && flash.length > 0) { %>
            <% flash.forEach(function(msg) { %>
            <div class="alert alert-<%= msg.type === 'error' ? 'danger' : 'success' %> alert-dismissible fade show">
                <%= msg.message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% }); %>
            <% } %>

            <div class="card">
                <div class="card-header bg-dark">
                    <h5 class="mb-0">Gestion des films</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Affiche</th>
                                    <th>Titre</th>
                                    <th>Date ajout</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (films && films.length > 0) { %>
                                <% films.forEach(function(film) { %>
                                <tr>
                                    <td><%= film.id %></td>
                                    <td>
                                        <img src="<%= film.cover %>" alt="<%= film.titre %>" class="admin-cover-thumb" onerror="this.src='/images/covers/default.jpg'">
                                    </td>
                                    <td><%= film.titre %></td>
                                    <td><%= film.date_added %></td>
                                    <td>
                                        <a href="/admin/edit/<%= film.id %>" class="btn btn-sm btn-primary">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        <form method="POST" action="/admin/delete/<%= film.id %>" style="display:inline;">
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Voulez-vous vraiment supprimer ce film?')">
                                                <i class="bi bi-trash"></i> Supprimer
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); %>
                                <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center py-4">Aucun film</td>
                                </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="text-light py-4 mt-5" style="background-color: <%= siteSettings.secondaryColor %>;">
        <div class="container text-center">
            <p class="mb-0"><%- siteSettings.footerText %></p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
