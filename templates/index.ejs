<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Streaming - Films en ligne</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-play-circle"></i> Streaming
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Accueil</a>
                    </li>
                </ul>
                <form class="d-flex" action="/search" method="get">
                    <input class="form-control me-2" type="search" name="q" placeholder="Rechercher...">
                    <button class="btn btn-outline-light" type="submit"><i class="bi bi-search"></i></button>
                </form>
                <ul class="navbar-nav ms-2">
                    <% if (session && session.user) { %>
                    <li class="nav-item">
                        <a class="btn btn-danger ms-2" href="/admin">Admin</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light ms-2" href="/logout">Déconnexion</a>
                    </li>
                    <% } else { %>
                    <li class="nav-item">
                        <a class="btn btn-primary ms-2" href="/login">Connexion</a>
                    </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <nav class="category-nav">
            <ul class="category-tabs">
                <li><a href="/" class="<%= !currentCategory ? 'active' : '' %>">Tous</a></li>
                <% categories.forEach(function(cat) { %>
                <li><a href="/category/<%= cat %>" class="<%= currentCategory === cat ? 'active' : '' %>"><%= cat.charAt(0).toUpperCase() + cat.slice(1) %></a></li>
                <% }); %>
            </ul>
        </nav>

        <% if (search_query) { %>
        <div class="container mt-4">
            <div class="alert alert-info">
                Résultats pour: "<strong><%= search_query %></strong>"
            </div>
        </div>
        <% } %>

        <div class="container-fluid px-4">
            <% if (films && films.length > 0) { %>
            <div class="film-row">
                <h2><%= currentCategory ? (currentCategory.charAt(0).toUpperCase() + currentCategory.slice(1)) : 'Films récents' %></h2>
                <div class="film-grid">
                    <% films.forEach(function(film) { %>
                    <a href="/film/<%= film.id %>" class="film-card">
                        <div class="film-poster">
                            <img src="<%= film.cover %>" alt="<%= film.titre %>" onerror="this.src='/images/covers/default.jpg'">
                            <div class="film-overlay">
                                <i class="bi bi-play-circle-fill play-icon"></i>
                            </div>
                        </div>
                        <div class="film-info">
                            <h6 class="film-title"><%= film.titre %></h6>
                            <span class="film-category"><%= film.categorie ? (film.categorie.charAt(0).toUpperCase() + film.categorie.slice(1)) : '' %></span>
                        </div>
                    </a>
                    <% }); %>
                </div>
            </div>
            <% } else { %>
            <div class="text-center py-5 mt-5">
                <i class="bi bi-film display-1 text-muted"></i>
                <p class="mt-3">Aucun film disponible dans cette catégorie</p>
            </div>
            <% } %>
        </div>
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 Streaming. Tous droits réservés.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
